<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="2"
       name="SauceDemo cross browser suit"
       parallel="tests">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Chrome">
        <parameter name="browser" value="chrome"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.FooterTest"/>
            <class name="tests.InventoryTest"/>
            <class name="tests.LocatorsTest"/>
            <class name="tests.LoginTest"/>
            <class name="tests.ShoppingCartTest"/>
            <class name="tests.SideBarTest"/>
        </classes>
    </test>

    <test name="Firefox">
        <parameter name="browser" value="firefox"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="tests.FooterTest"/>
            <class name="tests.InventoryTest"/>
            <class name="tests.LocatorsTest"/>
            <class name="tests.LoginTest"/>
            <class name="tests.ShoppingCartTest"/>
            <class name="tests.SideBarTest"/>
        </classes>
    </test>
</suite>
